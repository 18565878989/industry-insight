{
  "ontology_name": "Semiconductor Industry Ontology",
  "version": "1.0",
  "description": "Semiconductor industry knowledge graph ontology",
  "concepts": {
    "Design": {
      "description": "Chip design companies",
      "sub_concepts": ["Fabless", "EDA", "IP"],
      "properties": ["node_count", "process_node", "die_size"]
    },
    "Manufacturing": {
      "description": "Manufacturing companies",
      "sub_concepts": ["Foundry", "IDM", "OSAT"],
      "properties": ["fab_locations", "capacity", "process_nodes"]
    },
    "Materials": {
      "description": "Materials and chemicals",
      "sub_concepts": ["Silicon", "Photoresist", "Chemicals", "Gases"],
      "properties": ["purity", "supplier", "application"]
    },
    "Equipment": {
      "description": "Manufacturing equipment",
      "sub_concepts": ["Lithography", "Etch", "Deposition", "Inspection"],
      "properties": ["throughput", "accuracy", "supplier"]
    },
    "Packaging": {
      "description": "Packaging and testing",
      "sub_concepts": ["OSAT", "Advanced Packaging", "Testing"],
      "properties": ["technology", "capacity"]
    },
    "Products": {
      "description": "Semiconductor products",
      "sub_concepts": ["Logic", "Memory", "Analog", "RF", "Power"],
      "properties": ["performance", "application"]
    }
  },
  "relationships": {
    "SUPPLIES": "Material/Equipment supplier to manufacturer",
    "MANUFACTURES": " foundry to fabless company",
    "PARTNERS_WITH": "Strategic partnership",
    "COMPETES_WITH": "Competitive relationship",
    "ACQUIRES": "Acquisition relationship",
    "INVESTS_IN": "Investment relationship",
    "USES": "Product uses component",
    "LOCATED_IN": "Geographic location"
  },
