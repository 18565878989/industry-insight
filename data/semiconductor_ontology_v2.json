    },
    "Equipment": {
      "rdfs:comment": "Manufacturing equipment",
      "subClasses": ["Lithography", "Etch", "Deposition", "CMP", "Inspection"]
    }
  },
  "object_properties": {
    "manufactures": {"domain": "Company", "range": "Product"},
    "supplies_to": {"domain": "Company", "range": "Company"},
    "competes_with": {"domain": "Company", "range": "Company", "owl:SymmetricProperty": true},
